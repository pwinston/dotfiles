#!/usr/bin/env python3
"""wt — git worktree helper.

Creates sibling worktrees at ../<repo>-<name>, runs project hooks, and opens
them in cmux. Hooks live at:
  ~/.config/wt/hooks/<repo>/setup.sh    <target> <name> <main-repo>
  ~/.config/wt/hooks/<repo>/teardown.sh <target> <name> <main-repo>
"""

import argparse
import os
import re
import subprocess
import sys
from pathlib import Path
from shutil import which


# --- shell helpers --------------------------------------------------------
# Three primitives cover almost every shell-out we need. Each aborts on
# failure (matching bash `set -e`) so call-sites stay one-liners.

def run(*cmd, cwd=None):
    """Run cmd, stream output, abort on non-zero exit."""
    r = subprocess.run(cmd, cwd=cwd)
    if r.returncode:
        sys.exit(r.returncode)


def out(*cmd, cwd=None):
    """Capture stdout, strip, abort on non-zero exit."""
    r = subprocess.run(cmd, cwd=cwd, capture_output=True, text=True)
    if r.returncode:
        sys.stderr.write(r.stderr)
        sys.exit(r.returncode)
    return r.stdout.strip()


def ok(*cmd, cwd=None):
    """True iff cmd exits zero; silent."""
    return subprocess.run(cmd, cwd=cwd, capture_output=True).returncode == 0


def die(msg):
    print(f"wt: {msg}", file=sys.stderr)
    sys.exit(1)


# --- repo discovery -------------------------------------------------------

def repo_paths():
    if not ok("git", "rev-parse", "--is-inside-work-tree"):
        die("not inside a git repository")
    common = Path(out("git", "rev-parse", "--git-common-dir")).resolve()
    main_repo = common.parent
    return main_repo, main_repo.name, main_repo.parent


# --- subcommands ----------------------------------------------------------

def cmd_new(name):
    main_repo, repo_name, parent = repo_paths()
    target = parent / f"{repo_name}-{name}"
    if target.exists():
        die(f"new: {target} already exists")

    run("git", "-C", str(main_repo), "worktree", "add", str(target), "-b", name)

    hook = Path.home() / ".config/wt/hooks" / repo_name / "setup.sh"
    if os.access(hook, os.X_OK):
        print(f"wt new: running {hook}")
        run(str(hook), str(target), name, str(main_repo))

    if which("cmux"):
        pw_file = Path.home() / "Library/Application Support/cmux/socket-control-password"
        if "CMUX_SOCKET_PASSWORD" not in os.environ and pw_file.is_file():
            os.environ["CMUX_SOCKET_PASSWORD"] = pw_file.read_text().strip()
        # cmux output goes to user; capture-and-echo so we can scrape the workspace ref.
        ws_output = subprocess.run(
            ["cmux", "new-workspace", "--cwd", str(target)],
            stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True,
        ).stdout
        print(ws_output, end="")
        m = re.search(r"workspace:\d+", ws_output)
        if m:
            subprocess.run(
                ["cmux", "rename-workspace", "--workspace", m.group(0), name],
                stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
            )

    print(f"wt new: created {target}")


def cmd_remove(name):
    main_repo, repo_name, parent = repo_paths()
    cwd = Path.cwd()
    prefix = f"{parent}/{repo_name}-"

    if not name:
        cwd_str = str(cwd)
        if cwd_str.startswith(prefix):
            name = cwd_str[len(prefix):].split("/", 1)[0]
        else:
            die("remove: no name given and $PWD is not inside a sibling worktree")

    name = name.removeprefix(f"{repo_name}-")
    target = parent / f"{repo_name}-{name}"

    if not target.is_dir():
        listing = out("git", "-C", str(main_repo), "worktree", "list")
        if any(line.startswith(f"{target} ") for line in listing.splitlines()):
            print(f"wt remove: {target} already gone; pruning stale worktree record")
            run("git", "-C", str(main_repo), "worktree", "prune")
            print("wt remove: pruned")
            return
        die(f"remove: {target} does not exist")

    inside = cwd == target or target in cwd.parents

    hook = Path.home() / ".config/wt/hooks" / repo_name / "teardown.sh"
    if os.access(hook, os.X_OK):
        print(f"wt remove: running {hook}")
        run(str(hook), str(target), name, str(main_repo))

    run("git", "-C", str(main_repo), "worktree", "remove", str(target))
    print(f"wt remove: removed {target}")
    if inside:
        print(f"wt remove: your shell is now in a deleted dir — run: cd {main_repo}")
    print("wt remove: close its cmux workspace manually (cmux list-workspaces / close-workspace)")


def cmd_list():
    main_repo, _, _ = repo_paths()
    run("git", "-C", str(main_repo), "worktree", "list")


# --- entry point ----------------------------------------------------------

def main():
    p = argparse.ArgumentParser(
        prog="wt",
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sub = p.add_subparsers(dest="cmd", required=True)
    s_new = sub.add_parser("new", help="create sibling worktree ../<repo>-<name>")
    s_new.add_argument("name")
    s_rm = sub.add_parser("remove", help="remove sibling worktree (default: deduce from $PWD)")
    s_rm.add_argument("name", nargs="?")
    sub.add_parser("list", help="list worktrees for the current repo")

    args = p.parse_args()
    if args.cmd == "new":
        cmd_new(args.name)
    elif args.cmd == "remove":
        cmd_remove(args.name)
    elif args.cmd == "list":
        cmd_list()


if __name__ == "__main__":
    main()
